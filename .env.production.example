# ============================================================
# La Bella Pizzeria — variables d'environnement PRODUCTION
# Copiez ce fichier en `.env` sur le serveur et complétez.
# ⚠️ Ne committez JAMAIS le vrai .env (déjà dans .gitignore).
# ============================================================

# Domaine public (URLs absolues Stripe, sitemap, OG). OBLIGATOIRE.
NEXT_PUBLIC_SITE_URL="https://labellapizzeria.fr"

# Secret de session admin — OBLIGATOIRE, fort et unique (>= 32 caractères).
# En production, l'app REFUSE de démarrer si ce secret est absent/faible.
# Générer : openssl rand -base64 32
AUTH_SECRET=""

# Connexion par comptes de DÉMO (mot de passe "demo") :
# désactivée automatiquement en production. Ne JAMAIS mettre "true" sur un site
# live ; uniquement pour un environnement de préproduction temporaire.
ALLOW_DEMO_LOGIN="false"

# Mot de passe initial des comptes admin créés par `npm run db:seed` (à changer).
SEED_ADMIN_PASSWORD=""

# --- Base de données (optionnelle : sans, le site tourne sur données démo) ---
# Mettre PERSIST_ORDERS="true" pour écrire les commandes en base.
DATABASE_URL="postgresql://user:password@localhost:5432/labella?schema=public"
PERSIST_ORDERS="false"

# --- Paiements Stripe (optionnel : sans clé = mode démo) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Emails de confirmation (optionnel : sans clé = journalisé) ---
RESEND_API_KEY=""
CONTACT_TO_EMAIL="contact@labellapizzeria.fr"
CONTACT_FROM_EMAIL="La Bella <commande@labellapizzeria.fr>"

# --- SMS / IA (optionnels) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
ANTHROPIC_API_KEY=""
