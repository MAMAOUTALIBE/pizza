# ============================================================
# La Bella Pizzeria — variables d'environnement
# Copier en .env.local (Next) / .env (Prisma) et compléter.
# ============================================================

# Base de données (Prisma / PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/labella?schema=public"

# Persistance des commandes : "true" pour écrire les commandes en base (Prisma).
# Laissé vide/false = mode démo (commandes journalisées, pas de DB requise).
PERSIST_ORDERS="false"

# Authentification admin (à générer : openssl rand -base64 32)
AUTH_SECRET="change-me-in-production"

# URL publique du site (pour les URLs absolues Stripe success/cancel).
# En local, l'origine de la requête est utilisée par défaut.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Paiements Stripe — sans STRIPE_SECRET_KEY, le tunnel bascule en mode démo
# (paiement simulé). Clés de test sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Emails transactionnels (Resend ou SMTP)
RESEND_API_KEY=""
CONTACT_TO_EMAIL="contact@labellapizzeria.fr"
CONTACT_FROM_EMAIL="La Bella <onboarding@resend.dev>"

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Assistant IA (Anthropic)
ANTHROPIC_API_KEY=""
